Bootstrap: docker
From: ubuntu:22.04

# Custom container: AMULET v1.0 + restriction lists
# Used for ATAC doublet detection

%labels
    Description "AMULET v1.0 doublet detection for ATAC-seq"

%environment
    export PATH="/opt/AMULET:$PATH"

%post
    apt-get update -qq && apt-get install -y --no-install-recommends \
        openjdk-17-jre-headless python3 python3-pip git curl unzip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

    git clone --depth 1 https://github.com/UcarLab/AMULET /opt/AMULET

    curl -fsSL \
        https://github.com/UcarLab/AMULET/releases/download/v1.0/RestrictionRepeatLists.zip \
        -o /tmp/lists.zip \
    && unzip /tmp/lists.zip -d /opt/AMULET/ \
    && rm /tmp/lists.zip

    chmod +x /opt/AMULET/*.py /opt/AMULET/AMULET.sh 2>/dev/null || true

    pip3 install --no-cache-dir numpy scipy
