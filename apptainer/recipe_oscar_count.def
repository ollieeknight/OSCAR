Bootstrap: docker
From: ubuntu:22.04

%labels
    name "Oliver Knight"
    email "oliver.knight@charite.de"

%files
    cellranger-9.0.1.tar.gz /opt/
    cellranger-atac-2.2.0.tar.gz /opt/

%environment
    export LC_ALL=C
    export LC_NUMERIC=en_GB.UTF-8
    export PATH="/opt/cellranger-atac-2.2.0:/opt/cellranger-9.0.1:/usr/local/bin:$PATH"
    . /opt/miniforge3/etc/profile.d/conda.sh
    conda activate oscar_count

%runscript
    #!/bin/bash
    . /opt/miniforge3/etc/profile.d/conda.sh
    conda activate oscar_count
    eval ${@}

%post
    #!/bin/bash
    set -e

    # Install runtime dependencies
    apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Extract Cell Ranger
    tar -xf /opt/cellranger-9.0.1.tar.gz -C /opt/ && \
    tar -xf /opt/cellranger-atac-2.2.0.tar.gz -C /opt/ && \
    rm /opt/cellranger-9.0.1.tar.gz /opt/cellranger-atac-2.2.0.tar.gz

    # Install Miniforge
    curl -L "https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh" -o Miniforge3-Linux-x86_64.sh && \
    bash Miniforge3-Linux-x86_64.sh -b -p "/opt/miniforge3" && \
    rm Miniforge3-Linux-x86_64.sh

    . /opt/miniforge3/etc/profile.d/conda.sh

    # Create conda environment (without upgrade to save space/time)
    conda create -y -n oscar_count -c https://repo.prefix.dev/romitools -c bioconda -c conda-forge \
        bcl2fastq2 \
        fastqc \
        multiqc \
        pandas \
        pip && \
    conda clean -y -a

    # Activate conda environment for pip installation
    conda activate oscar_count

    # Install Kallisto pre-built binary
    curl -L "https://github.com/pachterlab/kallisto/releases/download/v0.51.1/kallisto_linux-v0.51.1.tar.gz" -o /tmp/kallisto.tar.gz && \
    tar -xzf /tmp/kallisto.tar.gz -C /tmp && \
    mv /tmp/kallisto/kallisto /usr/local/bin/ && \
    rm -rf /tmp/kallisto /tmp/kallisto.tar.gz

    # Install bustools pre-built binary
    curl -L "https://github.com/BUStools/bustools/releases/download/v0.45.1/bustools_linux-master.tar.gz" -o /tmp/bustools.tar.gz && \
    tar -xzf /tmp/bustools.tar.gz -C /tmp && \
    mv /tmp/bustools/bustools /usr/local/bin/ && \
    rm -rf /tmp/bustools /tmp/bustools.tar.gz

    # Install asap_to_kite and bio
    pip install --no-cache-dir git+https://github.com/ollieeknight/asap_to_kite.git bio && \
    pip cache purge

    # Install kite (only featuremap script needed)
    git clone --depth 1 https://github.com/pachterlab/kite /tmp/kite && \
    mkdir -p /opt/kite/featuremap && \
    cp /tmp/kite/featuremap/featuremap.py /opt/kite/featuremap/ && \
    sed -i '1s|^.*$|#!/opt/miniforge3/envs/oscar_count/bin/python\n&|' /opt/kite/featuremap/featuremap.py && \
    chmod +x /opt/kite/featuremap/featuremap.py && \
    rm -rf /tmp/kite

    # Disable cellranger telemetry
    /opt/cellranger-9.0.1/cellranger telemetry disable

    # Remove git (no longer needed)
    apt-get purge -y --auto-remove git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Remove conda package cache and tarballs
    conda clean -y --all --force-pkgs-dirs