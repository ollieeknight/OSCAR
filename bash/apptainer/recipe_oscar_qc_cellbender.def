Bootstrap: docker
From: pytorch/pytorch:2.0.1-cuda11.7-cudnn8-runtime

%labels
    name "Oliver Knight"
    email "oliver.knight@charite.de"
    description "CellBender container with CUDA 11.7 for AG Romagnani"

%runscript
    exec "$@"

%post
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        git \
        ca-certificates

    # Install CellBender directly using pip (resolves all dependencies automatically)
    pip install --no-cache-dir -U git+https://github.com/broadinstitute/CellBender.git@4334e8966217c3591bf7c545f31ab979cdc6590d

    # Clean up to keep the image compact
    apt-get clean
    rm -rf /var/lib/apt/lists/*