workDir = '/sc-scratch/sc-scratch-cc12-ag-romagnani/nf_work'

env {
    APPTAINER_TMPDIR   = '/sc-scratch/sc-scratch-cc12-ag-romagnani/tmp/nf_work_oscar'
    APPTAINER_CACHEDIR = '/home/knighto/bin/apptainer/cache'
}

params {
    // Input
    samplesheet     = null   // path to metadata.csv (identical format to current OSCAR metadata.csv)
    bcl_dir         = null   // path to BCL folder containing RunInfo.xml
    outdir          = 'results'
    from_fastq      = false  // start from pre-existing FASTQs in params.fastq_dir
    from_cellranger = false  // start from cellranger outputs in params.outs_dir
    fastq_dir       = null   // required when from_fastq = true
    outs_dir        = null   // required when from_cellranger = true
    adt_files_dir   = null   // directory containing ADT CSV files ({adt_file}.csv)
    extra_bcl_dirs      = null   // comma-separated additional BCL dirs for multi-run
    extra_samplesheets  = null   // comma-separated samplesheets aligned with extra_bcl_dirs (one per extra BCL dir)
    run_until           = null   // stop pipeline after stage: 'FASTQ' | 'cellranger' | null (full run)
    run_name            = 'run'  // output prefix for _fastq / _outs dirs; set via --run_name R463

    // Human references
    ref_human          = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/GRCh38-hardmasked-optimised-arc"
    ref_vdj_human      = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/GRCh38-IMGT-VDJ-2024"

    // Mouse references
    ref_mouse          = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/mm/GRCm38-hardmasked-optimised-arc"
    ref_vdj_mouse      = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/mm/GRCm38-IMGT-VDJ-2024"

    // QC references
    snp_vcf            = "/sc-projects/sc-proj-cc12-ag-romagnani/ref/hs/SNP/genome1K.phase3.SNP_AF5e2.chr1toX.hg38.vcf.gz"
    atac_whitelist     = "/home/knighto/bin/cellranger-atac-2.2.0/lib/python/atac/barcodes/737K-cratac-v1.txt.gz"

    // Sequencer model — fallback ONLY for --from-fastq / --from-cellranger runs where
    // no BCL dir (and therefore no RunInfo.xml) is available for auto-detection.
    // When starting from BCL, the instrument is auto-detected from RunInfo.xml and
    // this value is ignored. Valid values: 'novaseq_x' | 'novaseq6000'
    sequencer              = 'novaseq_x'

    // Containers — nf-core public images (10x tools)
    container_bclconvert        = "quay.io/nf-core/bclconvert:4.4.6_1"
    container_cellranger        = "quay.io/nf-core/cellranger:10.0.0"
    container_cellranger_atac   = "quay.io/nf-core/cellranger-atac:2.1.0"

    // Containers — public images (QC tools)
    container_amulet       = "quay.io/cellgeni/amulet:1.1"
    container_mgatk        = "quay.io/ollieeknight/mgatk2:latest"

    // Containers — custom .sif (no public equivalent)
    container_asap         = "/home/knighto/bin/apptainer/cache/oscar-asap.sif"
    container_cellbender   = "/home/knighto/bin/apptainer/cache/oscar-cellbender.sif"

    // Containers — public biocontainers (pinned)
    container_falco        = "quay.io/biocontainers/falco:1.3.0--h3be2455_0"
    container_multiqc      = "quay.io/biocontainers/multiqc:1.34--pyhdfd78af_0"
    container_kallisto     = "quay.io/biocontainers/kallisto:0.51.1--h7d033e6_0"
    container_bustools     = "quay.io/biocontainers/bustools:0.45.1--h9f5acd7_0"
    container_cellsnp      = "quay.io/biocontainers/cellsnp-lite:1.2.3--ha0c3a46_6"
    container_vireo        = "quay.io/biocontainers/vireosnp:0.5.9--pyh7e72e81_0"

    multiqc_config         = "${projectDir}/assets/multiqc_config.yaml"

    // MACS3 peak calling (ATAC libraries)
    container_macs3        = "quay.io/biocontainers/macs3:3.0.1--py311h320fe9a_1"
    macs3_qvalue           = 0.05     // FDR threshold for peak calling

    // Scrublet doublet detection (GEX/CITE/DOGMA libraries)
    container_scrublet     = "quay.io/biocontainers/scrublet:0.2.3--pyh5e36f6f_0"
    scrublet_doublet_rate  = 0.06     // expected doublet rate (default ~6% for standard 10x loading)
}

profiles {
    standard {
        process.executor  = 'local'
        apptainer.enabled = true
        apptainer.autoMounts = true
    }

    slurm {
        process.executor  = 'slurm'
        process.queue     = 'compute'
        apptainer.enabled     = true
        apptainer.autoMounts  = true
        apptainer.cacheDir    = "/home/knighto/bin/apptainer/cache"
        apptainer.envWhitelist = ['APPTAINER_TMPDIR', 'APPTAINER_CACHEDIR']
        apptainer.runOptions  = '--bind /charite-store-f/f-cc12-ag-romagnani,/sc-projects/sc-proj-cc12-ag-romagnani,/sc-scratch/sc-scratch-cc12-ag-romagnani,/home/knighto'

        process {
            errorStrategy = { task.attempt < 2 ? 'retry' : 'finish' }
            maxRetries    = 1

            withLabel: 'process_low' {
                cpus   = 2
                memory = 8.GB
                time   = 4.h
            }
            withLabel: 'process_medium' {
                cpus   = 8
                memory = 32.GB
                time   = 12.h
            }
            withLabel: 'process_high' {
                cpus   = 16
                memory = 64.GB
                time   = 24.h
            }
            withLabel: 'process_gpu' {
                queue            = 'gpu'
                clusterOptions   = '--gres=gpu:1'
                containerOptions = '--nv'
                cpus             = 16
                memory           = 96.GB
                time             = 24.h
            }

            withName: 'GENERATE_SAMPLESHEET' {
                executor = 'local'
            }
            withName: 'BCL_TO_FASTQ' {
                cpus   = 16
                memory = 32.GB
                time   = 12.h
            }
            withName: 'CELLRANGER_MULTI|CELLRANGER_ATAC' {
                cpus   = 64
                memory = 128.GB
                time   = 48.h
            }
            withName: 'CELLSNP_LITE|VIREO' {
                cpus   = 32
                memory = 64.GB
                time   = 48.h
            }
            withName: 'MGATK2' {
                cpus   = 32
                memory = 128.GB
                time   = 48.h
            }
            withName: 'KALLISTO_BUS' {
                cpus   = 16
                memory = 96.GB
                time   = 48.h
            }
        }
    }
}
