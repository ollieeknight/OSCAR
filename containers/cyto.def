Bootstrap: docker
From: ubuntu:22.04

%labels
    org.opencontainers.image.source https://github.com/arcinstitute/cyto
    org.opencontainers.image.description "cyto — 10x Flex scRNA-seq processing (ARC Institute)"

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -y && apt-get install -y --no-install-recommends \
        curl \
        git \
        ca-certificates \
        build-essential \
        cmake \
        libssl-dev \
        pkg-config \
        zlib1g-dev \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

    # ── Install Rust toolchain ────────────────────────────────────────────────
    export CARGO_HOME=/opt/cargo
    export RUSTUP_HOME=/opt/rustup
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --default-toolchain stable
    export PATH="/opt/cargo/bin:$PATH"
    rustup show

    # ── Clone cyto and build ──────────────────────────────────────────────────
    # Pin to a specific commit for reproducibility.
    # Update CYTO_COMMIT when upgrading.
    CYTO_COMMIT="main"
    git clone --depth 1 https://github.com/arcinstitute/cyto /opt/cyto-src
    cd /opt/cyto-src

    # target-cpu=native optimises for the build node's CPU microarchitecture.
    # Build and execute nodes should be the same CPU family on BIH HPC (AVX2+).
    # Remove the flag if building on a different machine than where jobs run.
    cargo install --path crates/cyto --root /usr/local --locked

    # ── Clean build artefacts to reduce image size ────────────────────────────
    cd /
    rm -rf /opt/cyto-src
    rm -rf /opt/cargo/registry /opt/cargo/git
    # Keep rustup/cargo env for bqtools if needed later; strip binaries
    strip /usr/local/bin/cyto 2>/dev/null || true

%environment
    export PATH=/usr/local/bin:$PATH
    export CARGO_HOME=/opt/cargo
    export RUSTUP_HOME=/opt/rustup
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%test
    cyto --version
    cyto map gex --help > /dev/null
    cyto workflow gex --help > /dev/null
    echo "cyto container OK"

%runscript
    exec cyto "$@"
